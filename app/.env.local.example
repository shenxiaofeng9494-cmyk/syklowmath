# ============================================
# MathTalkTV 环境变量配置
# ============================================
# 复制此文件为 .env.local 并填写你的 API 密钥

# ============================================
# 语音交互方案（三选一，至少配置一个）
# ============================================

# 方案一：OpenAI Realtime API（旧版）
# OPENAI_API_KEY=sk-...

# 方案二：Doubao Realtime S2S（豆包实时语音）
# DOUBAO_API_TOKEN=your-api-token

# 方案三：Doubao ASR + Doubao LLM + Doubao TTS（推荐）
# DOUBAO_API_KEY=6078f037-1fad-4d6c-8308-5aa9a4207ed9
# DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL_ENDPOINT=ep-20250119143058-lzl6k
# DOUBAO_API_TOKEN=your-api-token
# DOUBAO_ASR_RESOURCE_ID=volc.bigasr.sauc.duration
# DOUBAO_TTS_RESOURCE_ID=volc.megatts.default
# DOUBAO_TTS_VOICE=zh_female_tianmeixiaoyuan_moon_bigtts

# ============================================
# AI 游戏生成（可选）
# ============================================
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # 可选：自定义 API 端点
# GAME_AGENT_MODEL=claude-opus-4-5-20251101

# ============================================
# 数据库和存储（可选，但推荐配置）
# ============================================

# Supabase（用于 RAG 向量检索和数据存储）
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# 认证（必需）
# ============================================
# JWT_SECRET=your-random-secret-at-least-32-chars

# 阿里云短信（可选，不配置时验证码打印到控制台）
# ALIYUN_SMS_ACCESS_KEY_ID=your-key-id
# ALIYUN_SMS_ACCESS_KEY_SECRET=your-key-secret
# ALIYUN_SMS_SIGN_NAME=MathTalkTV
# ALIYUN_SMS_TEMPLATE_CODE=SMS_xxx

# 阿里云 DashScope（语音识别和向量嵌入）
# DASHSCOPE_API_KEY=sk-...

# 阿里云 OSS（视频存储）
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=your-bucket
# OSS_ACCESS_KEY_ID=your-key-id
# OSS_ACCESS_KEY_SECRET=your-key-secret

# ============================================
# Volcengine（可选，用于视觉场景分割）
# ============================================
# VOLCENGINE_ACCESS_KEY_ID=...
# VOLCENGINE_ACCESS_KEY_SECRET=...
